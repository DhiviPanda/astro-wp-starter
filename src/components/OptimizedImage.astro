---
interface Props {
  src: string;
  localPath?: string;
  alt: string;
  width: number;
  height?: number;
  class?: string;
  loading?: 'lazy' | 'eager';
}

const { 
  src, 
  localPath, 
  alt, 
  width, 
  height, 
  class: className = '',
  loading = 'lazy' 
} = Astro.props;

// Si tenemos localPath, usar esa (ya está optimizada)
// Si no, usar src original
const imageSrc = localPath || src;
---

<img 
  src={imageSrc}
  alt={alt}
  width={width}
  height={height}
  loading={loading}
  class={className}
/>